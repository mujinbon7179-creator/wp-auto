# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# GitHub (Required — for triggering workflows from dashboard)
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_REPO=your-username/wp-auto

# Instance mode (central instance only — self-hosted forks leave this unset)
# NEXT_PUBLIC_INSTANCE_MODE=central
